# =========================
# REQUIRED (minimum)
# =========================
# One or multiple topic keywords separated by commas, e.g. world news,AI,fintech
TARGET_TOPIC=world news
RSS_URLS=https://news.google.com/rss/search?q=world+news&hl=en-US&gl=US&ceid=US:en

# Fill at least one delivery channel (Telegram or VK)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
VK_GROUP_ID=
VK_ACCESS_TOKEN=

# =========================
# COMMON (usually adjusted)
# =========================
TARGET_LANGUAGE=ru
SCHEDULE_CRON=*/30 * * * *
TIMEZONE=Europe/Moscow
MAX_NEWS_PER_RUN=3
NEWS_MAX_AGE_DAYS=1
DATABASE_PATH=./data/news.db

TELEGRAM_ACTIVE_HOURS=
VK_ACTIVE_HOURS=
TELEGRAM_SHOW_SOURCE=true
VK_SHOW_SOURCE=true
DIRECT_PUBLISH_ENABLED=true

# =========================
# LLM (optional)
# =========================
LLM_ENABLED=false
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_BASE_URL=https://api.openai.com/v1
SUMMARY_MAX_LINES=3
LLM_SUMMARY_PROMPT=You are an editor for Telegram and VK digest posts. Write in '{target_language}'. Return exactly {summary_max_lines} lines, each line starts with '• '. Keep it factual and concise, no hype, no markdown, no date/source/link repetition.

# =========================
# LINKS (optional)
# =========================
SHORT_LINKS_ENABLED=false
SHORTENER_PROVIDER=isgd

# =========================
# VK advanced (optional)
# =========================
VK_PHOTO_UPLOAD_ENABLED=true
VK_DRAFT_MODE=false
VK_DRAFT_DELAY_MINUTES=43200
VK_DAILY_POST_LIMIT=0

# =========================
# DEDUP / SAFETY (advanced)
# =========================
DEDUP_CLEANUP_ENABLED=true
DEDUP_RETENTION_DAYS=90
POST_ATTEMPTS_RETENTION_DAYS=30
REQUIRE_IMAGE_FOR_PUBLISH=false
DUPLICATE_ACTION=skip

EVENT_TAG_DEDUP_ENABLED=false
EVENT_TAG_DEDUP_WINDOW_DAYS=1
EVENT_TAG_DEDUP_MIN_TOKENS=4

SIMILAR_DEDUP_ENABLED=true
SIMILAR_DEDUP_WINDOW=15
SIMILAR_DEDUP_THRESHOLD=0.90
SIMILAR_DEDUP_TOKEN_THRESHOLD=0.72
SIMILAR_DEDUP_MIN_OVERLAP_TOKENS=6

# =========================
# HUB integration (advanced)
# =========================
HUB_ENABLED=false
HUB_BASE_URL=
HUB_API_KEY=
HUB_TIMEOUT_SECONDS=15
HUB_CREATE_JOBS=true
HUB_SEND_DUPLICATES=false
