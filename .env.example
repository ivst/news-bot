# Core
# Set any topic keyword, e.g. world news, AI, fintech, anime, etc.
TARGET_TOPIC=world news
TARGET_LANGUAGE=ru
SCHEDULE_CRON=*/30 * * * *
TIMEZONE=Europe/Moscow
MAX_NEWS_PER_RUN=3
DATABASE_PATH=./data/news.db

# RSS sources (comma-separated)
RSS_URLS=https://news.google.com/rss/search?q=world+news&hl=en-US&gl=US&ceid=US:en

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# VK
VK_GROUP_ID=
VK_ACCESS_TOKEN=

# Optional OpenAI for higher quality summary/translation
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TRANSLATION_ENABLED=false

# Optional short links in posts
SHORT_LINKS_ENABLED=true
SHORTENER_PROVIDER=isgd

# Optional dedup DB cleanup
DEDUP_CLEANUP_ENABLED=true
DEDUP_RETENTION_DAYS=90

# Backward-compatible aliases
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
