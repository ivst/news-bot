[Unit]
Description=NEWS BOT Service (%i)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=news-bot
WorkingDirectory=/opt/news-bot
EnvironmentFile=/opt/news-bot/.env.%i
ExecStart=/opt/news-bot/.venv/bin/python /opt/news-bot/main.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
